<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/tarabytes"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.MidtermsExam_Beauty"
        tools:targetApi="31">

        <activity
            android:name=".display.RegisterActivity"
            android:exported="false">
        </activity>
        <activity
            android:name=".display.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".display.SkinType"
            android:exported="false" />
        <activity
            android:name=".display.ViewProductDetails"
            android:exported="false" />
        <activity
            android:name=".display.FeaturedProducts"
            android:exported="false" />
        <activity
            android:name=".display.PopularProducts"
            android:exported="false" />
        <activity
            android:name=".display.Checkout"
            android:exported="false" />
        <activity
            android:name=".display.Homepage"
            android:exported="false" >
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true" >


            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>
    </application>

</manifest>
