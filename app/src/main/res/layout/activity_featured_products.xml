<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".display.FeaturedProducts">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1C1C1C">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:elevation="8dp"
            android:background="#212121"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="71dp"
                android:layout_height="74dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/tarabytes"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:gravity="center_vertical"
                android:text="TaraBytes"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.3"
                android:fontFamily="@font/lexend_black"
                android:textSize="27sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- Content Section -->
        <LinearLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingHorizontal="12dp">

            <!-- Back + Title Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageButton
                    android:id="@+id/back_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/back_icon"
                    android:backgroundTint="#FF5722"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Featured Products"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/lexend_semibold"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="40dp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <!-- Accent divider -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_gravity="center_horizontal"
                android:background="#FF5722"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="-8dp"/>

            <ListView
                android:id="@+id/featured_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#00000000"
                android:divider="#2A2A2A"
                android:dividerHeight="8dp"
                android:clickable="true"
                tools:ignore="KeyboardInaccessibleWidget" />

        </LinearLayout>

        <!-- Bottom Navigation Bar -->
        <LinearLayout
            android:id="@+id/navigation_bar"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="#212121"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:gravity="center"
            android:weightSum="6">

            <ImageButton
                android:id="@+id/toHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/home_icon"
                android:tint="#9E9E9E"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toRatings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/popular_icon"
                android:tint="#9E9E9E"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toSkinTypes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/skin_type_icon"
                android:tint="#9E9E9E"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toFeatured"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/featured_icon"
                android:tint="#FF5722"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toPayment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/check_out_icon"
                android:tint="#9E9E9E"
                tools:ignore="ContentDescription" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>