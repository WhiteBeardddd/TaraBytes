<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.user.Homepage"
    android:background="#1C1C1C">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:elevation="8dp"
        android:background="#212121"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="start|center_vertical"
            android:src="@drawable/tarabytes"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/lexend_black"
            android:gravity="center_vertical"
            android:letterSpacing="0.3"
            android:text="TaraBytes"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />


        <ImageButton
            android:id="@+id/toProfile"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:padding="10dp"
            android:layout_marginLeft="7dp"
            android:layout_gravity="center"
            android:background="@drawable/rounded_profile_bg_green"
            android:contentDescription="Profile Icon"
            android:src="@drawable/ic_profile"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


    </LinearLayout>

    <!-- Scrollable Content -->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#1C1C1C"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/navigation_bar">

        <LinearLayout
            android:id="@+id/scrollablePart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="10dp">

            <!-- Featured Products -->


            <LinearLayout
                android:id="@+id/homepage_search_bar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="12dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/border_inv">

                <ImageView
                    android:id="@+id/search_bar_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical"
                    app:srcCompat="@android:drawable/ic_menu_search"
                    android:tint="#9E9E9E"
                    tools:ignore="ContentDescription" />

                <EditText
                    android:id="@+id/searchEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search (e.g. chicken adobo)"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#9E9E9E"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    tools:ignore="HardcodedText" />

            </LinearLayout>

            <TextView
                android:id="@+id/featured_products_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Featured Shops"
                android:textColor="#00C853"
                android:fontFamily="@font/lexend_black"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/featured_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#00000000"
                android:nestedScrollingEnabled="false" />

            <!-- Popular Products -->
            <TextView
                android:id="@+id/popular_products_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Popular Orders"
                android:fontFamily="@font/lexend_black"
                android:textColor="#00C853"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/popular_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#00000000"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <include
        android:id="@+id/navigation_bar"
        layout="@layout/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>