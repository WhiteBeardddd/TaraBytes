<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_dark_bg"
    tools:context=".views.seller.SellerDashboard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_black"
            android:text="Seller Dashboard"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/lexend_regular"
            android:text="Seller tools will live here. For now, this screen keeps a clean logout path for seller accounts."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnSellerLogout"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/cta_secondary"
            android:elevation="0dp"
            android:fontFamily="@font/lexend_semibold"
            android:text="Log Out"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            tools:ignore="ButtonStyle,HardcodedText" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
