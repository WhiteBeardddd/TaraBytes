<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_dark_bg"
    tools:context=".views.user.UserProfile">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_elevated"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/lexend_black"
                android:text="Account"
                android:textColor="@color/white"
                android:textSize="24sp"
                tools:ignore="HardcodedText" />

            <ImageButton
                android:id="@+id/settings_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/settings_gear"
                android:backgroundTint="#FF5722"
                tools:ignore="ContentDescription" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_semibold"
                        android:text="Username"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />

                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_surface"
                        android:hint="Full Name"
                        android:padding="14dp"
                        android:textColor="@color/color_gray"
                        android:textColorHint="@color/text_muted"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/textView2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/lexend_semibold"
                        android:text="Phone Number"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_surface"
                        android:hint="Phone Number"
                        android:inputType="phone"
                        android:padding="14dp"
                        android:textColor="@color/color_gray"
                        android:textColorHint="@color/text_muted"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/lexend_semibold"
                        android:text="Balance"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/etBalance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/input_surface"
                        android:hint="₱ 69420"
                        android:padding="14dp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/surface_card"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageButton
                        android:id="@+id/order_btn"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:background="@drawable/icon_button_bg"
                        android:padding="16dp"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/wallet_icon"
                        android:contentDescription="Orders"
                        app:tint="@color/color_primary"
                        tools:ignore="HardcodedText" />

                    <ImageButton
                        android:id="@+id/fav_btn"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:background="@drawable/icon_button_bg"
                        android:padding="16dp"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/heart_icon"
                        android:contentDescription="Favorites"
                        app:tint="@color/status_danger"
                        tools:ignore="HardcodedText" />

                    <ImageButton
                        android:id="@+id/address_btn"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:background="@drawable/icon_button_bg"
                        android:padding="16dp"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/location_icon"
                        android:contentDescription="Address"
                        app:tint="@color/color_accent_teal"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/surface_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSellerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_semibold"
                            android:text="Seller Mode"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/lexend_regular"
                            android:text="Enable this if you want to manage a store."
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchIsSeller"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical">

                    <!-- TITLE -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="General"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend_semibold"
                        android:padding="18dp"
                        tools:ignore="HardcodedText" />

                    <!-- ================= SUPPORT ================= -->
                    <LinearLayout
                        android:id="@+id/headerSupport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Help Center"
                            android:textColor="@color/white"
                            tools:ignore="HardcodedText" />

                        <ImageView
                            android:id="@+id/arrowSupport"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/down_chevron"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentSupport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingStart="32dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Contact us"
                            android:padding="10dp"
                            android:textColor="@color/text_secondary"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="FAQs"
                            android:padding="10dp"
                            android:textColor="@color/text_secondary"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                    <!-- ================= TERMS ================= -->
                    <LinearLayout
                        android:id="@+id/headerTerms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Terms &amp; policies"
                            android:textColor="@color/white"
                            tools:ignore="HardcodedText"/>

                        <ImageView
                            android:id="@+id/arrowTerms"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/down_chevron"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentTerms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingStart="32dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Privacy Policy"
                            android:padding="10dp"
                            android:textColor="@color/text_secondary"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="User Agreement"
                            android:padding="10dp"
                            android:textColor="@color/text_secondary"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                </LinearLayout>

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/cta_primary"
                    android:elevation="0dp"
                    android:fontFamily="@font/lexend_bold"
                    android:text="Save Profile"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    tools:ignore="ButtonStyle,HardcodedText" />

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/cta_secondary"
                    android:elevation="0dp"
                    android:fontFamily="@font/lexend_semibold"
                    android:text="Log Out"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    tools:ignore="ButtonStyle,HardcodedText" />
            </LinearLayout>
        </ScrollView>

        <include
            android:id="@+id/navigation_bar"
            layout="@layout/layout_navbar" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
