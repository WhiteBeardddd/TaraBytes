<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.user.ViewProductDetails">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/gradient_bg_004">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="99dp"
            android:elevation="8dp"
            android:background="@drawable/gradient_bg_002"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="71dp"
                android:layout_height="74dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/beauty_logo"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:gravity="center_vertical"
                android:text="Beautify"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.3"
                android:fontFamily="@font/grand_hotel_regular"
                android:textSize="27sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/back_btn"
            android:layout_width="50dp"
            android:layout_height="45dp"
            android:background="@drawable/back_icon"
            android:backgroundTint="@color/white"
            android:clickable="true"
            android:focusable="true"
            tools:ignore="ContentDescription" />

        <!-- Product Details -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/productName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cetaphil"
                    android:fontFamily="@font/lexend_bold"
                    android:textColor="@color/black"
                    android:textSize="37sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/itemCard"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/display_image"
                            android:layout_width="match_parent"
                            android:layout_height="321dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/product_1"
                            tools:ignore="ContentDescription" />

                        <!-- Price and Rating Centered -->
                        <TextView
                            android:id="@+id/productPrice"
                            android:layout_width="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:fontFamily="@font/lexend_bold"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:text="Price: 500 Gold"
                            android:textColor="@color/black"
                            android:textSize="25sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />

                        <TextView
                            android:id="@+id/star"
                            android:layout_width="wrap_content"
                            android:fontFamily="@font/lexend_extrabold"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:layout_gravity="center_horizontal"
                            android:text="⭐⭐⭐⭐⭐"
                            android:textColor="@color/black"
                            android:textSize="20sp"
                            tools:ignore="HardcodedText" />


                        <TextView
                            android:id="@+id/productRating"
                            android:layout_width="wrap_content"
                            android:fontFamily="@font/lexend_extrabold"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:layout_gravity="center_horizontal"
                            android:text="4.2"
                            android:textColor="@color/black"
                            android:textSize="20sp"
                            tools:ignore="HardcodedText" />

                        <!-- Left-aligned Texts -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="left"
                            android:orientation="vertical"
                            android:paddingStart="20dp"
                            tools:ignore="RtlHardcoded,RtlSymmetry">

                            <TextView
                                android:id="@+id/productDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Facial Cleanser"
                                android:textColor="@color/black"
                                android:textSize="20sp"
                                android:fontFamily="@font/lexend_regular"
                                android:layout_marginBottom="10dp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/productCategory"
                                android:layout_marginBottom="10dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loved"
                                android:fontFamily="@font/lexend_bold"
                                android:textColor="@color/black"
                                android:textSize="20sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/productSkinType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend_bold"
                                android:text="Dry"
                                android:layout_marginBottom="10dp"
                                android:textColor="@color/black"
                                android:textSize="20sp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar -->
        <LinearLayout
            android:id="@+id/navigation_bar"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:background="@drawable/gradient_bg_002"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:gravity="center"
            android:weightSum="6">

            <ImageButton
                android:id="@+id/toHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/home_icon"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toRatings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/popular_icon"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toSkinTypes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/skin_type_icon"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toFeatured"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/featured_icon"
                tools:ignore="ContentDescription" />

            <ImageButton
                android:id="@+id/toPayment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:background="@drawable/border_inv"
                android:elevation="8dp"
                android:src="@drawable/check_out_icon"
                tools:ignore="ContentDescription" />

        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
