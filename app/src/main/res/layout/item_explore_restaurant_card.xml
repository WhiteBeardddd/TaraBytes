<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/surface_elevated"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <ImageView
            android:id="@+id/explore_product_image"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:adjustViewBounds="true"
            android:background="@drawable/surface_card_soft"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/popular_product_1"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/explore_product_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/lexend_black"
            android:maxLines="2"
            android:text="Streetfood Ta Bai"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/explore_product_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/lexend_regular"
            android:maxLines="2"
            android:text="Strong seller with comfort food and approachable prices."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/explore_product_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/surface_card_soft"
                android:fontFamily="@font/lexend_semibold"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="Burgers"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/explore_product_availability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/pill_green"
                android:fontFamily="@font/lexend_semibold"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="Available"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/explore_product_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="@font/lexend_black"
                android:gravity="end"
                android:text="P199.00"
                android:textColor="@color/color_primary"
                android:textSize="20sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
