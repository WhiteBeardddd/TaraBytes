<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation_bar"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@color/surface_elevated"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp"
    android:weightSum="5">

    <ImageButton
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_margin="4dp"
        android:layout_weight="1"
        android:background="@drawable/surface_card_soft"
        android:elevation="0dp"
        android:padding="12dp"
        android:src="@drawable/home_icon"
        app:tint="@color/text_secondary"
        tools:ignore="ContentDescription" />

    <ImageButton
        android:id="@+id/nav_ratings"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_margin="4dp"
        android:background="@drawable/surface_card_soft"
        android:elevation="0dp"
        android:padding="12dp"
        android:src="@drawable/popular_icon"
        app:tint="@color/text_secondary"
        tools:ignore="ContentDescription" />

    <ImageButton
        android:id="@+id/nav_skin_types"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_margin="4dp"
        android:background="@drawable/surface_card_soft"
        android:elevation="0dp"
        android:padding="12dp"
        android:src="@drawable/skin_type_icon"
        app:tint="@color/text_secondary"
        tools:ignore="ContentDescription" />

    <ImageButton
        android:id="@+id/nav_featured"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_margin="4dp"
        android:background="@drawable/surface_card_soft"
        android:elevation="0dp"
        android:padding="12dp"
        android:src="@drawable/featured_icon"
        app:tint="@color/text_secondary"
        tools:ignore="ContentDescription" />

    <ImageButton
        android:id="@+id/nav_payment"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_margin="4dp"
        android:background="@drawable/surface_card_soft"
        android:elevation="0dp"
        android:padding="12dp"
        android:src="@drawable/check_out_icon"
        app:tint="@color/text_secondary"
        tools:ignore="ContentDescription" />

</LinearLayout>
