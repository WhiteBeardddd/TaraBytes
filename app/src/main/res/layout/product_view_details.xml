<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <LinearLayout
            android:id="@+id/product_details_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:fontFamily="@font/lexend_black"
                android:text="Adobo w/ Rice"
                android:textSize="22sp"
                android:textColor="@color/black_primary"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="2"
                android:gravity="center"
                tools:ignore="HardcodedText" />

            <ImageView
                android:id="@+id/product_image"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_margin="8dp"
                android:padding="2dp"
                app:srcCompat="@drawable/tarabytes" />

            <TextView
                android:id="@+id/product_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:lineSpacingExtra="2dp"
                android:text="This is where the meals description would go, Very delicious Adobo meal set that would fill you!"
                android:textSize="14sp"
                android:textColor="@color/gray_secondary"
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:id="@+id/product_category_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="2dp"
                android:orientation="horizontal">

                <!-- Left Col -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_black"
                        android:text="Category:"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/black_primary"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/product_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Protein"
                        android:textColor="@color/teal_accent"
                        android:textSize="14sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <!-- Right Col -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_black"
                        android:text="Price:"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/black_primary"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/product_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_black"
                        android:text="₱69420.00"
                        android:textColor="@color/green_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/product_quantity_control"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/product_buy_amount"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/minus_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/lexend_black"
                        android:text="-"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/green_primary"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/product_quantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/lexend_black"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        tools:ignore="HardcodedText" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/add_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/lexend_black"
                        android:text="+"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/green_primary"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/confirm_buy_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/lexend_black"
                    android:text="confirm"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/green_primary"
                    tools:ignore="HardcodedText" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/navigation_bar"
        layout="@layout/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>